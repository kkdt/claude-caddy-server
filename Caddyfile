# Caddy reverse proxy for local UI development
#
# Proxies local React UI traffic to remote API services using mTLS.
# Keycloak Bearer token is injected per-request via /tmp/caddy-token.conf,
# which is written and refreshed by entrypoint.sh.
#
# Required environment variables:
#   UPSTREAM_API_URL   Remote API base URL (e.g., https://api.example.com)
#   UI_ORIGIN          Local UI origin for CORS (e.g., http://localhost:3000)
#
# Certificate environment variables (set automatically by entrypoint.sh):
#   CLIENT_CERT_PATH   Path to client certificate for mTLS
#   CLIENT_KEY_PATH    Path to client private key for mTLS
#   CA_CERT_PATH       Path to CA certificate for verifying upstream
#
# Certificates are loaded from /certs if provided; otherwise entrypoint.sh
# generates self-signed certificates at /tmp/caddy-certs.

{
    # Enable admin API for graceful config reload during token refresh
    admin localhost:2019
}

:80 {
    log {
        output stdout
        level  INFO
        format json
    }

    # CORS — allow the local React UI to call this proxy from a different port.
    # Handles preflight OPTIONS requests and injects headers on all responses.
    @cors_preflight method OPTIONS
    handle @cors_preflight {
        header Access-Control-Allow-Origin      "{$UI_ORIGIN}"
        header Access-Control-Allow-Methods     "GET, POST, PUT, PATCH, DELETE, OPTIONS"
        header Access-Control-Allow-Headers     "Authorization, Content-Type, Accept"
        header Access-Control-Allow-Credentials "true"
        header Access-Control-Max-Age           "86400"
        respond "" 204
    }

    header Access-Control-Allow-Origin      "{$UI_ORIGIN}"
    header Access-Control-Allow-Credentials "true"

    reverse_proxy {$UPSTREAM_API_URL} {
        # mTLS: present client certificate when connecting to upstream.
        # Paths are set by entrypoint.sh — either from /certs or auto-generated.
        transport http {
            tls
            tls_client_auth      {$CLIENT_CERT_PATH} {$CLIENT_KEY_PATH}
            tls_trusted_ca_certs {$CA_CERT_PATH}
        }

        # Keycloak Bearer token — written at startup and refreshed automatically
        # by entrypoint.sh; caddy reload re-reads this file on each token refresh
        import /tmp/caddy-token.conf

        header_up Host              {upstream_hostport}
        header_up X-Real-IP         {remote_host}
        header_up X-Forwarded-For   {remote_host}
        header_up X-Forwarded-Proto {scheme}
    }
}
