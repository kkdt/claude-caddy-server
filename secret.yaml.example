# Keycloak client credentials secret — template
#
# 1. Copy this file:
#      cp secret.yaml.example secret.yaml
#
# 2. Base64-encode your values and replace the placeholders:
#      echo -n "your-client-id"     | base64
#      echo -n "your-client-secret" | base64
#
# 3. Apply the secret before deploying the pod:
#      podman kube play secret.yaml
#
# WARNING: Never commit secret.yaml with real credentials.
#          It is listed in .gitignore.

apiVersion: v1
kind: Secret
metadata:
  name: keycloak-creds
type: Opaque
data:
  client_id:     <base64-encoded-client-id>
  client_secret: <base64-encoded-client-secret>
